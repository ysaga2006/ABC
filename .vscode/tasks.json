{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build",
            "command": "/usr/local/bin/g++",
            "args": [
                "-g",
                "-std=c++20",
                "-Wall",
                "-Wextra",
                "-D_GLIBCXX_DEBUG",
                "-fsanitize=address",
                "-fsanitize=undefined",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": false
            }
        },
        {
            "type": "shell",
            "label": "Test",
            "command": "oj",
            "args": [
                "t",
                "-c",
                "./${fileBasenameNoExtension}",
                "-d",
                "test",
                "--timeout",
                "2"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "dependsOn": [
                "Build"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            }
        }
    ]
}